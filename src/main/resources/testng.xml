<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Sauce Demo" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="utils.RetryListener"/>
    </listeners>

    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.AddToCartTest"/>
            <class name="tests.LocatorTest"/>
            <class name="tests.GoToEmptyCart"/>
            <class name="tests.RemoveItemFromCart"/>
        </classes>
    </test>

    <test name="Firefox Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.AddToCartTest"/>
            <class name="tests.LocatorTest"/>
            <class name="tests.GoToEmptyCart"/>
            <class name="tests.RemoveItemFromCart"/>
        </classes>
    </test>

</suite>